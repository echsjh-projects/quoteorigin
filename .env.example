# Copy this to .env and fill in your values
# NEVER commit .env to GitHub

# --- Groq (free at console.groq.com) ---
GROQ_API_KEY=your_groq_api_key_here

# --- PostgreSQL (free at neon.tech) ---
# Local:   postgresql+asyncpg://postgres:password@localhost/quoteorigin
# Neon:    postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?ssl=require
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost/quoteorigin

# --- NewsAPI (free at newsapi.org — 100 req/day) ---
NEWS_API_KEY=your_newsapi_key_here

# --- Brave Search API (free at api.search.brave.com — 2000 req/month) ---
BRAVE_API_KEY=your_brave_api_key_here

# --- CORS: your Vercel frontend URL (add after deploying) ---
# During local dev, http://localhost:5173 is always allowed
FRONTEND_URL=https://your-app.vercel.app

# --- App settings ---
ENVIRONMENT=development   # change to "production" on Render
