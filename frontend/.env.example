# Copy to .env.local for local dev, set in Vercel dashboard for production
# VITE_ prefix is required — Vite only exposes variables with this prefix to the browser

# In local dev, leave this empty — the Vite proxy (vite.config.js) will forward /api to localhost:8000
# In production (Vercel), set this to your Render backend URL:
VITE_API_URL=https://quoteorigin-api.onrender.com
